# Konfiguracja deploy na serwer produkcyjny (Mikrus)
# Skopiuj jako .deploy.env i uzupełnij wartości

# Adres serwera Mikrus (np. srv03.mikr.us, frog01.mikr.us)
DEPLOY_HOST=srvXX.mikr.us

# Port SSH (10000 + numer maszyny, np. 10107)
DEPLOY_SSH_PORT=10XXX

# Użytkownik SSH (domyślnie root)
DEPLOY_USER=root

# Ścieżka do projektu na serwerze
DEPLOY_APP_DIR=/root/combo-raport-app

# Profil docker-compose (prod lub prod87)
DEPLOY_PROFILE=prod87

